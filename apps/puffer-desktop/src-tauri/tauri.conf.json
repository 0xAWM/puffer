{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Puffer Desktop",
  "version": "0.1.0",
  "identifier": "dev.puffer.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Puffer Desktop",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": "all"
  }
}
