{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Puffer Desktop",
  "version": "0.1.0",
  "identifier": "com.berabuddies.puffer.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Puffer Desktop",
        "width": 1500,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
